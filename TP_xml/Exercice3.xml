    <ligue>Coupe d'afrique des nations</ligue>
    <journee numero="1">
        <date>
            <jour>25</jour>
            <mois>Decembre</mois>
            <annee>2025</annee>
        </date>
        <rencontre>
            <equipe>Lions indomptables du cameroun</equipe>
            <equipe>Les panthères du gabon</equipe>
            <resultat>1-0</resultat>
        </rencontre>

        <rencontre>
            <equipe>Les éléphants de la côte d'ivoire</equipe>
            <equipe>Les antiloppes du mozambique</equipe>
            <resultat>1-0</resultat>
        </rencontre>
    </journee>
</championnat>