<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE championnat[
    <!ELEMENT championnat (annee, ligue, journee+)>
        <!ELEMENT annee (#PCDATA)>
        <!ELEMENT ligue (#PCDATA)>
        <!ELEMENT journee (date, rencontre+)>
            <!ATTLIST journee numero CDATA #REQUIRED>
            <!ELEMENT date (jour, mois, annee)>
            <!ELEMENT jour (#PCDATA)>
            <!ELEMENT mois (#PCDATA)>
            <!ELEMENT rencontre (equipe, equipe, resultat)>
                <!ELEMENT equipe (#PCDATA)>
                <!ELEMENT resultat (#PCDATA)>
]>
<championnat>
